# =============================================================================
# Actions Proxy — Environment Configuration
# =============================================================================
# Copy this to .env and source it, or export these variables directly.

# ─── Server ──────────────────────────────────────────────────────────────────
# HTTP bind address
BIND_ADDR=127.0.0.1:8090

# ─── Authentication ──────────────────────────────────────────────────────────
# API key required in X-API-Key header (required)
API_KEY=change-me-in-production

# ─── Chain / CLI ─────────────────────────────────────────────────────────────
# Path to posd binary
POSD_BIN=posd

# Tendermint RPC endpoint
POSD_NODE=http://localhost:26657

# Chain ID (required)
POSD_CHAIN_ID=omniphi-1

# Optional: posd home directory
# POSD_HOME=

# Key name in the keyring (required — must be funded and have gov authority)
KEY_NAME=copilot

# Keyring backend: test, file, os, kwallet, pass
KEYRING_BACKEND=test

# Transaction gas settings
TX_GAS=auto
TX_GAS_ADJUSTMENT=1.3

# Transaction fees — set ONE of these:
TX_FEES=2000uposd
# TX_GAS_PRICES=0.025uposd

# Broadcast mode: sync, async, or block
TX_BROADCAST_MODE=sync

# CLI command timeout (seconds)
TX_TIMEOUT_SECONDS=30

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Requests per second (0.2 = 1 request per 5 seconds)
RATE_LIMIT_RPS=0.2

# Maximum burst capacity
RATE_LIMIT_BURST=2

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (use * for development)
CORS_ALLOW_ORIGINS=*
