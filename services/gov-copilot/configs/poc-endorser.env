# ============================================================================
# PoC Endorser Configuration (Layer 3: Gov-Copilot)
#
# Copy this file to .env.poc-endorser and fill in your values.
# All values can be overridden via environment variables.
# ============================================================================

# --- Chain Connectivity ---
POSD_CHAIN_ID=omniphi-testnet-2
NODE_WS_URL=ws://localhost:26657/websocket
NODE_RPC_URL=http://localhost:26657
KEY_NAME=validator
KEYRING_BACKEND=test

# Transaction fees (set ONE of these)
TX_FEES=2000omniphi
# TX_GAS_PRICES=0.025omniphi
# TX_GAS=auto

# --- IPFS ---
IPFS_GATEWAY_URL=https://ipfs.io/ipfs/
FETCH_TIMEOUT_SECONDS=30
MAX_CONTENT_BYTES=524288

# --- AI Evaluation (OpenAI-compatible API) ---
OPENAI_API_KEY=sk-your-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
AI_TIMEOUT_SECONDS=60
AI_MAX_RETRIES=2

# --- Endorsement Thresholds (scores 0-10) ---
# Contributions scoring >= APPROVE_THRESHOLD get auto-approved
APPROVE_THRESHOLD=7.0
# Contributions scoring <= REJECT_THRESHOLD get auto-rejected
REJECT_THRESHOLD=3.0
# Contributions between thresholds are logged as "Manual Review Needed"

# --- Logging ---
LOG_LEVEL=info
