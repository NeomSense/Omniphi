# =============================================================================
# Gov Copilot — Environment Configuration
# =============================================================================
# Copy this to .env and source it, or export these variables directly.

# ─── Chain Connection ─────────────────────────────────────────────────────────
# Tendermint RPC endpoint (posd uses this for queries and tx broadcast)
POSD_NODE=http://localhost:26657

# Chain ID (required)
POSD_CHAIN_ID=omniphi-1

# Key name in the keyring (required — must be funded to pay tx fees)
KEY_NAME=copilot

# Keyring backend: test, file, os, kwallet, pass
KEYRING_BACKEND=test

# Transaction fees — set ONE of these:
TX_FEES=2000uposd
# TX_GAS_PRICES=0.025uposd
# TX_GAS=auto

# ─── Polling ──────────────────────────────────────────────────────────────────
# How often to check for new proposals (seconds)
POLL_INTERVAL_SECONDS=10

# Directory to write advisory reports
REPORT_DIR=./reports

# Reporter identifier embedded in each report
REPORTER_ID=gov-copilot-v1

# ─── DeepSeek AI ──────────────────────────────────────────────────────────────
# API key from https://platform.deepseek.com (required if AI_MODE=deepseek)
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DeepSeek API base URL (OpenAI-compatible)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Model to use (deepseek-chat or deepseek-reasoner)
DEEPSEEK_MODEL=deepseek-chat

# AI mode: "deepseek" (call API) or "template" (deterministic fallback)
AI_MODE=deepseek

# Request timeout per API call (seconds)
AI_TIMEOUT_SECONDS=20

# Max retries on API failure (with exponential backoff)
AI_MAX_RETRIES=2

# ─── Public Report Hosting ────────────────────────────────────────────────────
# Enable public URI generation (required for browser hash verification)
REPORT_PUBLIC_ENABLED=true

# Base URL where reports are served (no trailing slash)
# The copilot writes <proposal_id>.json locally; this URL tells the chain
# where browsers can fetch it. Must be backed by nginx/caddy or the built-in server.
REPORT_PUBLIC_BASE_URL=https://copilot.omniphi.org/reports

# ─── Built-in HTTP File Server (dev/testnet only) ────────────────────────────
# Serve REPORT_DIR over HTTP. In production, use nginx or caddy instead.
REPORT_HTTP_SERVE_ENABLED=false
REPORT_HTTP_BIND_ADDR=127.0.0.1:8088

# ─── State ────────────────────────────────────────────────────────────────────
# File to persist which proposals have been processed
STATE_FILE=./state.json
