# Omniphi Governance Dashboard — Environment Configuration
# Copy this to .env and edit the values.

# Cosmos LCD (REST) endpoint for governance queries
VITE_LCD_URL=http://localhost:1317

# Guard module REST endpoint (defaults to LCD_URL if not set)
VITE_GUARD_REST_URL=http://localhost:1317

# Polling interval in milliseconds (default: 8000)
VITE_POLL_MS=8000

# IPFS gateway for resolving ipfs:// advisory report URIs
# Default: https://ipfs.io/ipfs/
VITE_IPFS_GATEWAY=https://ipfs.io/ipfs/

# Backend actions proxy URL for confirm-execution (optional).
# Leave empty to disable the Confirm Execution button.
# Example: http://localhost:8080/api
VITE_BACKEND_ACTIONS_URL=

# API key for authenticating with the actions proxy (optional).
# Must match the API_KEY configured on the actions-proxy server.
VITE_BACKEND_API_KEY=
